# ============================================================================
# Quad — environment example
# Copy to .env and fill in. The app fails fast at boot if required vars are
# missing.
# ============================================================================

# ---- Node ----
NODE_ENV=development

# ---- App ----
# Port the Next server listens on (host machine + container). 3000 collides
# with a lot of dev tools — default 3010.
PORT=3010
# Public URL of the dashboard. Used for cookie domain + presigned URL redirects.
APP_URL=http://localhost:3010

# Cookie signing secret. Generate with: openssl rand -base64 48
# REQUIRED. App refuses to boot if missing or equal to this placeholder.
SESSION_SECRET=replace-me-with-openssl-rand-base64-48

# ---- Instance bootstrap ----
# First email to be granted Super Admin on first boot (must match the email
# used at signup).
# REQUIRED.
SUPER_ADMIN_EMAIL=you@example.com

# Allow open public signup? Default false for self-hosted safety. When false,
# users join only via invite or join-request flow.
INSTANCE_SIGNUP_OPEN=false

# ---- Database (Postgres) ----
# Railway auto-injects DATABASE_URL when you add the Postgres plugin.
# For docker-compose this is set in docker/docker-compose.yml.
DATABASE_URL=postgres://quad:quad@localhost:5432/quad

# ---- Storage (S3-compatible) ----
# Railway Storage Bucket auto-injects these. For docker-compose, MinIO is
# preconfigured in docker/docker-compose.yml. For EC2/Fly, point to your
# AWS S3 / Cloudflare R2 / MinIO / Backblaze B2 setup.
BUCKET_NAME=quad
BUCKET_ENDPOINT=http://localhost:9000
BUCKET_ACCESS_KEY_ID=minioadmin
BUCKET_SECRET_KEY=minioadmin
BUCKET_REGION=auto
# Public base for presigned GET URLs. If unset, derived from BUCKET_ENDPOINT.
BUCKET_PUBLIC_URL=

# ---- OpenAI (Whisper STT only) ----
# Optional. If unset, STT is disabled and videos/audios are stored without
# transcripts. Quad does NOT call any other OpenAI endpoint.
OPENAI_API_KEY=

# Monthly cap on Whisper audio minutes per instance. STT auto-suspends when
# crossed. 0 = no cap.
WHISPER_MONTHLY_MINUTES_CAP=0

# ---- Email (transactional) ----
# Required for invite emails, password reset, reporter notifications. Provider
# is Resend by default (free tier covers self-host needs).
EMAIL_PROVIDER=resend
EMAIL_PROVIDER_KEY=
EMAIL_FROM=Quad <noreply@example.com>
