# ============================================================================
# Quad — environment example
# Copy to .env and fill in. The app fails fast at boot if required vars are
# missing.
# ============================================================================

# ---- Node ----
NODE_ENV=development

# ---- App ----
# Port the Next server listens on (host machine + container). 3000 collides
# with a lot of dev tools — default 3010.
PORT=3010
# Public URL of the dashboard. Used for cookie domain + invite-link generation.
API_URL=http://localhost:3010

# Cookie signing secret. Generate with: openssl rand -base64 48
# REQUIRED. App refuses to boot if missing or equal to this placeholder.
SESSION_SECRET=replace-me-with-openssl-rand-base64-48

# ---- Instance bootstrap ----
# First email to be granted Super Admin. Sign up with this exact address
# and you're auto-promoted to super admin AND auto-activated (others land
# in 'pending' until you approve them at /admin/users).
# REQUIRED.
SUPER_ADMIN_EMAIL=you@example.com

# ---- Database (Postgres) ----
# Railway auto-injects DATABASE_URL when you add the Postgres plugin.
# For docker-compose this is set in docker/docker-compose.yml.
DATABASE_URL=postgres://quad:quad@localhost:5432/quad

# ---- Storage (S3-compatible) ----
# Railway Storage Bucket auto-injects these as-is. For docker-compose, MinIO
# is preconfigured in docker/docker-compose.yml. For EC2/Fly, point to your
# AWS S3 / Cloudflare R2 / MinIO / Backblaze B2 setup. Names match the
# AWS-SDK env conventions (no prefix).
BUCKET=quad
ENDPOINT=http://localhost:9000
ACCESS_KEY_ID=minioadmin
SECRET_ACCESS_KEY=minioadmin
REGION=auto
# Public base for presigned GET URLs. If unset, derived from ENDPOINT.
BUCKET_PUBLIC_URL=

# ---- OpenAI (Whisper STT only) ----
# Optional. If unset, STT is disabled and videos/audios are stored without
# transcripts. Quad does NOT call any other OpenAI endpoint.
OPENAI_API_KEY=

# Monthly cap on Whisper audio minutes per instance. STT auto-suspends when
# crossed. 0 = no cap.
WHISPER_MONTHLY_MINUTES_CAP=0

# Quad does not send email. Project invites are URL-only (the admin copies
# the invite link out of band). New signups land in 'pending' state and the
# super admin approves them at /admin/users.
